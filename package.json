{
  "name": "specmatic-ai-factory",
  "version": "1.0.0",
  "description": "Multi-Agent AI Software Factory with Specmatic — Research-oriented project demonstrating executable API contracts for AI-assisted development",
  "private": true,
  "workspaces": [
    "services/user-service",
    "services/task-service",
    "services/notification-service",
    "services/analytics-service",
    "agents",
    "dashboard"
  ],
  "scripts": {
    "install:all": "npm install",
    "start:user-service": "npm run start -w services/user-service",
    "start:task-service": "npm run start -w services/task-service",
    "start:notification-service": "npm run start -w services/notification-service",
    "start:analytics-service": "npm run start -w services/analytics-service",
    "start:services": "concurrently \"npm run start:user-service\" \"npm run start:task-service\" \"npm run start:notification-service\" \"npm run start:analytics-service\"",
    "start:dashboard": "npm run dev -w dashboard",
    "experiment": "npm run experiment -w agents",
    "contract:test:users": "npx specmatic test contracts/user-service.yaml --testBaseURL=http://localhost:3001 --resiliency",
    "contract:test:tasks": "npx specmatic test contracts/task-service.yaml --testBaseURL=http://localhost:3002 --resiliency",
    "contract:test:notifications": "npx specmatic test contracts/notification-service.yaml --testBaseURL=http://localhost:3003 --resiliency",
    "contract:test:analytics": "npx specmatic test contracts/analytics-service.yaml --testBaseURL=http://localhost:3004 --resiliency",
    "contract:test:all": "npm run contract:test:users && npm run contract:test:tasks && npm run contract:test:notifications && npm run contract:test:analytics",
    "examples:validate:users": "npx specmatic examples validate --spec-file contracts/user-service.yaml",
    "examples:validate:tasks": "npx specmatic examples validate --spec-file contracts/task-service.yaml",
    "examples:validate:notifications": "npx specmatic examples validate --spec-file contracts/notification-service.yaml",
    "examples:validate:analytics": "npx specmatic examples validate --spec-file contracts/analytics-service.yaml",
    "examples:validate:all": "npm run examples:validate:users && npm run examples:validate:tasks && npm run examples:validate:notifications && npm run examples:validate:analytics"
  },
  "devDependencies": {
    "@redocly/cli": "^2.33.2",
    "concurrently": "^9.1.0",
    "specmatic": "^2.47.0",
    "yaml": "^2.9.0"
  }
}
